{
    "name": "brimham/backup-monitor",
    "description": "Records and surfaces the health and history of your spatie/laravel-backup runs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "backup",
        "monitoring",
        "spatie",
        "backup-monitor"
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/events": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "spatie/laravel-backup": "^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Brimham\\BackupMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Brimham\\BackupMonitor\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "laravel/pint": "^1.29",
        "larastan/larastan": "^3.10"
    },
    "suggest": {
        "brimham/filament-backup-monitor": "A Filament panel (run history + per-destination health) for your backup runs"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Brimham\\BackupMonitor\\BackupMonitorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
